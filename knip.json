{
  "$schema": "https://unpkg.com/knip@6/schema.json",
  "workspaces": {
    ".": {
      "ignoreDependencies": [
        "@effect/tsgo",
        "@lerna-lite/publish",
        "@tanstack/eslint-plugin-router",
        "@tanstack/react-query",
        "@tanstack/react-router",
        "conventional-changelog-conventionalcommits",
        "kysely",
        "oxlint-plugin-eslint",
        "type-fest"
      ]
    },
    "apps/server": {
      "entry": ["src/app-layer.ts", "src/infrastructure-layer.ts"],
      "project": ["src/**/*.ts", "tests/**/*.ts"],
      "ignoreDependencies": ["cloudflare"]
    },
    "apps/web": {
      "project": ["src/**/*.{ts,tsx}", "tests/**/*.ts"],
      "ignoreDependencies": [
        "@fontsource-variable/geist",
        "@fontsource-variable/geist-mono",
        "shadcn",
        "tailwindcss",
        "tw-animate-css"
      ]
    },
    "apps/cli": {
      "entry": ["tests/interactive/harness/**/*.ts"],
      "project": ["src/**/*.ts", "tests/**/*.ts"],
      "ignoreDependencies": ["wrangler", "expo"],
      "ignoreBinaries": ["openssl", "keytool"]
    },
    "packages/api": {
      "project": ["src/**/*.ts"]
    },
    "packages/api-client": {
      "project": ["src/**/*.ts"]
    },
    "packages/react-hooks": {
      "project": ["src/**/*.ts"]
    },
    "packages/ui": {
      "entry": ["src/components/**/*.tsx", "src/hooks/*.ts", "src/lib/*.ts"],
      "project": ["src/**/*.{ts,tsx}"]
    },
    "packages/bsdiff": {
      "ignore": ["oxlint.config.mjs"],
      "ignoreDependencies": ["@better-update/bsdiff-.+"],
      "ignoreUnresolved": ["\\./bsdiff\\."]
    }
  },
  "ignoreDependencies": ["@better-update/oxlint-config"],
  "ignoreWorkspaces": ["packages/oxlint-config", "packages/typescript-config"],
  "ignoreExportsUsedInFile": true,
  "ignore": ["fixtures/**", "scripts/sync-bsdiff-versions.mjs"]
}
