{
  "name": "@better-update/cli",
  "version": "0.3.0",
  "bin": {
    "better-update": "./src/index.ts"
  },
  "type": "module",
  "exports": {
    ".": "./src/index.ts"
  },
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "lint": "oxlint --fix",
    "lint:check": "oxlint",
    "test": "vitest run --project unit",
    "test:e2e": "vitest run --project e2e --maxWorkers 1 --fileParallelism false",
    "test:interactive": "vitest run --project interactive --maxWorkers 1 --fileParallelism false",
    "test:watch": "vitest --project unit"
  },
  "dependencies": {
    "@better-update/api": "workspace:*",
    "@better-update/encoding": "workspace:*",
    "@better-update/expo-protocol": "workspace:*",
    "@better-update/safe-json": "workspace:*",
    "@effect/cli": "^0.75.1",
    "@effect/platform": "^0.96.0",
    "@effect/platform-bun": "^0.89.0",
    "@expo/apple-utils": "^2.1.21",
    "@expo/config": "^55.0.15",
    "@expo/pkcs12": "^0.4.2",
    "@expo/plist": "^0.5.2",
    "@expo/xcpretty": "^4.4.3",
    "bplist-parser": "^0.3.2",
    "effect": "^3.21.1",
    "es-toolkit": "^1.45.1",
    "gradle-to-js": "^2.0.1"
  },
  "devDependencies": {
    "@better-update/oxlint-config": "workspace:*",
    "@better-update/typescript-config": "workspace:*",
    "node-pty": "^1.1.0"
  },
  "optionalDependencies": {
    "keychain": "^1.5.0"
  }
}
