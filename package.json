{
  "name": "better-update",
  "private": true,
  "license": "MIT",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "type": "module",
  "scripts": {
    "build": "turbo run build",
    "check": "turbo run lint:check format:check",
    "check:bsdiff": "node scripts/check-bsdiff-release.mjs",
    "d1:migrate": "turbo run d1:migrate",
    "dev": "turbo run dev",
    "dev:proxy": "portless proxy start",
    "dev:proxy:stop": "portless proxy stop",
    "dev:trust": "portless trust",
    "fix": "turbo run lint format",
    "format": "oxfmt --write .",
    "format:check": "oxfmt --check .",
    "knip": "knip",
    "lint": "turbo run lint",
    "lint:check": "turbo run lint:check",
    "prepare": "lefthook install --force",
    "release:preview": "lerna version --conventional-commits --dry-run",
    "release:publish": "lerna publish from-package --yes",
    "release:version": "lerna version --conventional-commits --yes --no-push",
    "test": "turbo run test",
    "test:all": "bun run test && bun run test:integrations && bun run test:e2e",
    "test:e2e": "turbo run test:e2e",
    "test:integrations": "turbo run test:integrations",
    "typegen:cf": "turbo run typegen:cf",
    "verify": "node scripts/self-verify.mjs",
    "verify:e2e": "node scripts/self-verify.mjs --only=e2e"
  },
  "dependencies": {
    "@tanstack/react-query": "^5.101.2",
    "@tanstack/react-router": "^1.170.18"
  },
  "devDependencies": {
    "@commitlint/cli": "^21.2.1",
    "@commitlint/config-conventional": "^21.2.0",
    "@effect/language-service": "^0.87.0",
    "@effect/tsgo": "^0.19.0",
    "@effect/vitest": "^0.30.0",
    "@lerna-lite/cli": "^5.4.1",
    "@lerna-lite/publish": "^5.4.1",
    "@tanstack/eslint-plugin-router": "^1.162.0",
    "@types/node": "^26.1.1",
    "conventional-changelog-conventionalcommits": "^10.2.1",
    "knip": "^6.26.0",
    "lefthook": "^2.1.10",
    "oxfmt": "^0.59.0",
    "oxlint": "^1.74.0",
    "oxlint-plugin-eslint": "1.74.0",
    "oxlint-tsgolint": "^0.24.0",
    "portless": "^0.15.2",
    "turbo": "^2.10.5",
    "type-fest": "^5.8.0",
    "typescript": "^7.0.2",
    "vitest": "^4.1.10"
  },
  "overrides": {
    "kysely": "0.29.3"
  },
  "packageManager": "bun@1.3.13",
  "patchedDependencies": {
    "@tanstack/react-router@1.170.18": "patches/@tanstack%2Freact-router@1.170.18.patch",
    "kysely@0.29.3": "patches/kysely@0.29.3.patch"
  }
}
